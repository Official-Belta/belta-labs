# ========================================
# BELTA Labs 배포 환경변수
# ========================================
# 이 파일을 .env로 복사한 후 값을 채워주세요
# cp .env.example .env

# ─── 지갑 ──────────────────────────────
# 배포자 지갑 프라이빗 키 (0x 포함)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ─── RPC URLs ──────────────────────────
# Alchemy 또는 Infura에서 발급
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
UNICHAIN_SEPOLIA_RPC_URL=https://sepolia.unichain.org

# ─── 컨트랙트 주소 (체인별) ──────────────
# Sepolia
POOL_MANAGER=0xE03A1074c86CFeDd5C142C4F04F1a1536e203543
# Unichain Sepolia의 경우:
# POOL_MANAGER=0x00B036b58a818B1BC34d502D3fE730Db729e62AC

# USDC (Sepolia 테스트 토큰 — 직접 배포하거나 기존 것 사용)
UNDERLYING_ASSET=0xYOUR_TEST_USDC_ADDRESS

# ─── Etherscan 검증 ───────────────────
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# ─── 선택사항 ──────────────────────────
# Keeper 주소 (Gelato/Chainlink Automation)
KEEPER_ADDRESS=
